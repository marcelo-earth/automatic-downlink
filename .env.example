# HuggingFace token (for model download)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx

# Mapbox access token (OPTIONAL — only needed for Mapbox endpoints)
# Free tier: https://account.mapbox.com/auth/signup/
# Sentinel-2 endpoints work without this.
MAPBOX_ACCESS_TOKEN=pk.xxxxxxxxxxxxxxxxxxxxx

# Modal token (for fine-tuning on cloud GPUs)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
